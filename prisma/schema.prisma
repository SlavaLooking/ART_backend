// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "schema_users", "schema_catalog", "schema_orders", "schema_notifications"] 
}

// --- МОДЕЛИ ДЛЯ СХЕМЫ USERS (Auth + Profile) ---
model User { // Это будут учетные данные
  id                Int       @id @default(autoincrement())
  email             String    @unique
  password          String    // Здесь будет храниться хеш пароля
  refreshToken      String?   // Хеш refresh токена
  refreshTokenExpiresAt DateTime?

  profile           UserProfile? // Связь с профилем
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@schema("schema_users") // Эта таблица живет в схеме users
}

model UserProfile { // Это будет сам профиль пользователя
  id                Int       @id @default(autoincrement())
  userId            Int       @unique // Ссылка на User
  user              User      @relation(fields: [userId], references: [id]) // Связь один-к-одному

  firstName         String?
  lastName          String?
  deliveryAddress   String? // Можно сделать отдельную таблицу Address
  phone             String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@schema("schema_users") // Эта таблица также живет в схеме users
}

// --- МОДЕЛИ ДЛЯ СХЕМЫ CATALOG ---
model Artwork {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  price       Float
  imageUrl    String?
  isSold      Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@schema("schema_catalog")
}

// ... здесь будут другие модели для схем "orders" и "notifications" ...



